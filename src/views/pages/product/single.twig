{% extends "layouts.master" %}

{% block title %}{{ product.name }} - {{ store.name }}{% endblock %}

{% block content %}
  {% component 'header.breadcrumbs' %}

  <div class="container mx-auto px-4 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
      {# Product images #}
      <div class="dar-product-gallery">
        <div class="relative rounded-dar overflow-hidden bg-white border border-dar-cream-300">
          <salla-slider id="product-images" auto-height>
            {% for image in product.images %}
              <div class="swiper-slide">
                <img src="{{ image.url }}" alt="{{ image.alt | default(product.name) }}" class="w-full h-auto object-contain" loading="lazy">
              </div>
            {% endfor %}
          </salla-slider>
        </div>

        {# Thumbnails #}
        {% if product.images | length > 1 %}
          <div class="flex gap-2 mt-4 overflow-x-auto">
            {% for image in product.images %}
              <button class="flex-shrink-0 w-16 h-16 rounded-lg border-2 border-dar-cream-300 hover:border-dar-olive overflow-hidden transition-colors">
                <img src="{{ image.url }}" alt="" class="w-full h-full object-cover">
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      {# Product info #}
      <div class="dar-product-info">
        {% if product.brand.name %}
          <a href="{{ product.brand.url }}" class="text-dar-olive text-sm font-medium mb-2 inline-block hover:underline">{{ product.brand.name }}</a>
        {% endif %}

        <h1 class="text-2xl md:text-3xl font-bold text-dar-dark mb-2">{{ product.name }}</h1>

        {% if product.subtitle %}
          <p class="text-dar-dark-400 mb-4">{{ product.subtitle }}</p>
        {% endif %}

        {# Rating #}
        <div class="mb-4">
          <salla-rating-stars value="{{ product.rating.stars }}" size="md"></salla-rating-stars>
        </div>

        {# Price #}
        <div class="flex items-baseline gap-3 mb-6">
          {% if product.is_on_sale %}
            <span class="text-3xl font-bold text-dar-brown">{{ product.sale_price | money }}</span>
            <span class="text-lg text-dar-dark-400 line-through">{{ product.regular_price | money }}</span>
          {% else %}
            <span class="text-3xl font-bold text-dar-dark">{{ product.price | money }}</span>
          {% endif %}
        </div>

        {% hook 'product:single.description.start' %}

        {# Description #}
        {% if product.description %}
          <div class="dar-product-desc prose prose-sm max-w-none text-dar-dark-400 mb-6 pb-6 border-b border-dar-cream-300">
            {{ product.description | raw }}
          </div>
        {% endif %}

        {% hook 'product:single.description.end' %}

        {% hook 'product:single.form.start' %}

        {# Product options #}
        {% if product.options | length > 0 %}
          <div class="space-y-4 mb-6">
            {% for option in product.options %}
              <div class="dar-option">
                <label class="block text-sm font-medium text-dar-dark mb-2">
                  {{ option.name }}
                  {% if option.required %}<span class="text-dar-brown">*</span>{% endif %}
                </label>
                {{ option.element() }}
              </div>
            {% endfor %}
          </div>
        {% endif %}

        {# Quantity + Add to cart #}
        <div class="flex items-center gap-4 mb-6">
          <salla-quantity-input max="{{ product.max_quantity }}" product-id="{{ product.id }}" class="dar-qty"></salla-quantity-input>
          <salla-add-product-button product-id="{{ product.id }}" class="flex-1">
            <button class="w-full bg-dar-olive text-white py-3 px-6 rounded-dar font-medium hover:bg-dar-olive-dark transition-colors flex items-center justify-center gap-2">
              <i class="sicon-shopping-bag"></i>
              {{ trans('pages.product.add_to_cart') }}
            </button>
          </salla-add-product-button>
        </div>

        {% hook 'product:single.form.end' %}

        {# Wishlist + Share #}
        <div class="flex items-center gap-4 pt-4 border-t border-dar-cream-300">
          <button onclick="salla.wishlist.toggle({{ product.id }})" class="flex items-center gap-2 text-sm text-dar-dark-400 hover:text-dar-brown transition-colors">
            <i class="sicon-heart"></i>
            {{ trans('pages.product.add_to_wishlist') }}
          </button>
          <salla-social-share class="dar-share"></salla-social-share>
        </div>

        {# Availability #}
        {% if not product.is_available %}
          <salla-product-availability product-id="{{ product.id }}" class="mt-4"></salla-product-availability>
        {% endif %}
      </div>
    </div>

    {# Similar products #}
    {% component 'product.similar-products' %}

    {# Comments #}
    {% component comments %}
  </div>
{% endblock %}

{% block scripts %}
  <script defer src="{{ 'product.js' | asset }}"></script>
{% endblock %}
