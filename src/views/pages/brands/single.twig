{% extends "layouts.master" %}

{% block title %}{{ brand.name }} - {{ store.name }}{% endblock %}

{% block content %}
  {% component 'header.breadcrumbs' %}

  <div class="container mx-auto px-4 py-8">
    <div class="flex items-center gap-4 mb-8">
      {% if brand.logo %}
        <img src="{{ brand.logo }}" alt="{{ brand.name }}" class="h-12 w-auto">
      {% endif %}
      <h1 class="text-2xl md:text-3xl font-bold text-dar-dark">{{ brand.name }}</h1>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
      {% for product in products %}
        <salla-product-card product-id="{{ product.id }}" class="dar-product-card"></salla-product-card>
      {% endfor %}
    </div>
  </div>
{% endblock %}
