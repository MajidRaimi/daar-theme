{% extends "layouts.master" %}

{% block title %}{{ trans('pages.brands.title') }} - {{ store.name }}{% endblock %}

{% block content %}
  {% component 'header.breadcrumbs' %}

  <div class="container mx-auto px-4 py-8">
    <h1 class="text-2xl md:text-3xl font-bold text-dar-dark mb-8">{{ trans('pages.brands.title') }}</h1>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      {% for brand in brands %}
        <a href="{{ brand.url }}" class="bg-white rounded-dar border border-dar-cream-300 p-6 flex flex-col items-center justify-center hover:border-dar-olive hover:shadow-md transition-all group">
          {% if brand.logo %}
            <img src="{{ brand.logo }}" alt="{{ brand.name }}" class="h-16 w-auto object-contain mb-3">
          {% endif %}
          <span class="text-sm font-medium text-dar-dark group-hover:text-dar-olive transition-colors">{{ brand.name }}</span>
        </a>
      {% endfor %}
    </div>
  </div>
{% endblock %}
