{% extends "layouts.master" %}

{% block title %}{{ trans('pages.wishlist.title') }} - {{ store.name }}{% endblock %}

{% block content %}
  <salla-breadcrumb></salla-breadcrumb>

  <div class="container mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold text-dar-dark mb-8">{{ trans('pages.wishlist.title') }}</h1>

    {% hook 'customer:wishlist.items.start' %}

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
      {% for product in products %}
        <salla-product-card product-id="{{ product.id }}" class="dar-product-card"></salla-product-card>
      {% endfor %}
    </div>

    {% hook 'customer:wishlist.items.end' %}
  </div>
{% endblock %}
