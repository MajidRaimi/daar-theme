{% extends "layouts.master" %}

{% block title %}{{ page.title }} - {{ store.name }}{% endblock %}

{% block content %}
  <salla-breadcrumb></salla-breadcrumb>

  <div class="container mx-auto px-4 py-8">
    <article class="max-w-3xl mx-auto">
      <h1 class="text-3xl font-bold text-dar-dark mb-8">{{ page.title }}</h1>
      <div class="prose prose-lg max-w-none text-dar-dark-400">
        {{ page.content | raw }}
      </div>
    </article>
  </div>
{% endblock %}
