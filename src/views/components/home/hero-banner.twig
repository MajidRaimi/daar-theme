<section class="dar-hero relative overflow-hidden bg-dar-olive min-h-[60vh] flex items-center">
  {# Geometric pattern overlay - SVG inspired by the brand's Islamic geometric motif #}
  <div class="absolute inset-0 opacity-10 pointer-events-none">
    <svg class="w-full h-full" viewBox="0 0 400 400" preserveAspectRatio="xMidYMid slice">
      <pattern id="dar-geo" x="0" y="0" width="100" height="100" patternUnits="userSpaceOnUse">
        <rect width="100" height="100" fill="none" stroke="currentColor" stroke-width="0.5" class="text-white"/>
        <rect x="10" y="10" width="80" height="80" fill="none" stroke="currentColor" stroke-width="0.5" class="text-white" transform="rotate(15, 50, 50)"/>
        <rect x="20" y="20" width="60" height="60" fill="none" stroke="currentColor" stroke-width="0.5" class="text-white" transform="rotate(30, 50, 50)"/>
        <rect x="30" y="30" width="40" height="40" fill="none" stroke="currentColor" stroke-width="0.5" class="text-white" transform="rotate(45, 50, 50)"/>
      </pattern>
      <rect width="100%" height="100%" fill="url(#dar-geo)"/>
    </svg>
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-2xl {% if theme.is_rtl %}mr-0{% else %}ml-0{% endif %}">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-4">
        {{ component.title | default(trans('blocks.home.welcome')) }}
      </h1>
      {% if component.subtitle %}
        <p class="text-lg md:text-xl text-dar-cream-200 mb-8 leading-relaxed">
          {{ component.subtitle }}
        </p>
      {% endif %}
      {% if component.show_cta %}
        <a href="{{ page('products') }}" class="inline-flex items-center gap-2 bg-dar-brown text-white px-8 py-3 rounded-dar font-medium hover:bg-dar-brown-dark transition-colors">
          {{ trans('blocks.home.shop_now') }}
          <i class="sicon-keyboard_arrow_{% if theme.is_rtl %}left{% else %}right{% endif %}"></i>
        </a>
      {% endif %}
    </div>
  </div>
</section>
