<section class="dar-categories py-16">
  <div class="container mx-auto px-4">
    <div class="text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-bold text-dar-dark mb-2">
        {{ component.title | default(trans('blocks.home.categories')) }}
      </h2>
      <div class="w-16 h-0.5 bg-dar-olive mx-auto"></div>
    </div>

    <salla-products-list source="categories" class="dar-categories-grid">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-{{ component.columns | default(4) }} gap-6">
        {# Categories are auto-populated #}
      </div>
    </salla-products-list>
  </div>
</section>
