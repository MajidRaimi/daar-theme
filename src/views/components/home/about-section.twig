<section class="dar-about py-16 bg-dar-cream-100">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div class="{% if theme.is_rtl %}order-2 md:order-1{% endif %}">
        <h2 class="text-2xl md:text-3xl font-bold text-dar-dark mb-4">
          {{ component.title | default(trans('blocks.home.about_title')) }}
        </h2>
        <div class="w-12 h-0.5 bg-dar-olive mb-6"></div>
        <p class="text-dar-dark-400 leading-relaxed text-lg">
          {{ component.description | default(store.description) }}
        </p>
      </div>
      <div class="{% if theme.is_rtl %}order-1 md:order-2{% endif %}">
        {% if component.image %}
          <div class="relative rounded-dar overflow-hidden shadow-lg">
            <img src="{{ component.image[0] }}" alt="{{ component.title }}" class="w-full h-auto object-cover">
            {# Geometric accent #}
            <div class="absolute top-4 {% if theme.is_rtl %}left-4{% else %}right-4{% endif %} w-16 h-16 border-2 border-dar-olive opacity-50 transform rotate-45"></div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>
