<header class="dar-header fixed top-0 left-0 right-0 z-50 px-4 pt-4">
  <nav class="w-full max-w-6xl mx-auto rounded-2xl border border-gray-200 bg-white/80 backdrop-blur-xl">
    <div class="relative flex items-center justify-between h-14 px-4">

      <a href="{{ store.url }}" class="shrink-0 relative z-10">
        {% if store.logo %}
          <img src="{{ store.logo|cdn(175) }}" alt="{{ store.name }}" class="h-7 w-auto">
        {% else %}
          <span class="text-lg font-bold">{{ store.name }}</span>
        {% endif %}
      </a>

      <div class="hidden md:flex items-center gap-1 absolute inset-0 justify-center pointer-events-none">
        <div class="flex items-center gap-1 pointer-events-auto">
          <salla-menu></salla-menu>
        </div>
      </div>

      <div class="hidden md:flex items-center gap-3 shrink-0 relative z-10">
        <salla-search></salla-search>
        <salla-cart-summary></salla-cart-summary>
      </div>

      <button class="md:hidden p-2" onclick="document.getElementById('dar-mobile-nav').classList.toggle('hidden')">
        <i class="sicon-menu text-xl"></i>
      </button>

    </div>

    <div id="dar-mobile-nav" class="md:hidden hidden px-5 py-4">
      <salla-menu></salla-menu>
      <salla-search class="mt-3"></salla-search>
    </div>

  </nav>
</header>
<div class="h-20"></div>
