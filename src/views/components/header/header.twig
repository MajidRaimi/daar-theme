<header class="dar-header-wrapper fixed top-0 left-0 right-0 z-50 px-4 pt-4 transition-all duration-500">
  <nav class="w-full max-w-6xl mx-auto rounded-2xl border transition-all duration-500 border-dar-dark/[0.06] bg-dar-cream-50/80 backdrop-blur-xl">
    <div class="relative flex items-center justify-between h-14 px-3">

      {# Logo #}
      <a class="shrink-0 relative z-10" href="{{ store.url }}">
        {% if store.logo %}
          <img src="{{ store.logo|cdn(175) }}" alt="{{ store.name }}" loading="lazy" class="h-7 w-auto">
        {% else %}
          <span class="text-lg font-bold text-dar-dark">{{ store.name }}</span>
        {% endif %}
      </a>

      {# Centered nav links - desktop #}
      <div class="hidden md:flex items-center gap-1 absolute inset-0 justify-center pointer-events-none">
        <div class="flex items-center gap-1 pointer-events-auto">
          <salla-menu></salla-menu>
        </div>
      </div>

      {# Right actions - desktop #}
      <div class="hidden md:flex items-center gap-3 shrink-0 relative z-10">
        {# Localization #}
        <salla-localization-modal class="dar-lang-btn"></salla-localization-modal>

        {# Cart CTA #}
        <salla-cart-summary class="dar-cart-btn"></salla-cart-summary>
      </div>

      {# Hamburger - mobile #}
      <button class="dar-burger md:hidden relative w-9 h-9 flex items-center justify-center p-2" aria-label="Menu"
        onclick="this.classList.toggle('is-open'); var m=document.getElementById('dar-mobile-nav'); m.classList.toggle('is-open');">
        <span class="absolute block w-5 h-px bg-dar-dark transition-all duration-300 -translate-y-[5px]"></span>
        <span class="absolute block w-5 h-px bg-dar-dark transition-all duration-300"></span>
        <span class="absolute block w-5 h-px bg-dar-dark transition-all duration-300 translate-y-[5px]"></span>
      </button>

    </div>

    {# Mobile dropdown #}
    <div id="dar-mobile-nav" class="md:hidden transition-all duration-300 overflow-hidden max-h-0">
      <div class="px-5 py-4 space-y-1">
        <salla-menu></salla-menu>

        <div class="flex items-center gap-2 mt-3 pt-3 border-t border-dar-dark/[0.06]">
          <salla-cart-summary></salla-cart-summary>
          <salla-localization-modal></salla-localization-modal>
        </div>
      </div>
    </div>

  </nav>
</header>

{# Spacer #}
<div class="h-[72px]"></div>
